<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="webforms">
            <tab>mageme</tab>
            <resource>MageMe_WebForms::settings</resource>
            <group id="freshdesk" translate="label comment" sortOrder="300" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Freshdesk Integration Add-on</label>
                <comment>General settings that are required to connect Freshdesk Support and Magento.</comment>
                <field id="domain" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="0">
                    <label>Freshdesk Domain</label>
                    <comment>Freshdesk address: ***.freshdesk.com</comment>
                </field>
                <field id="api_key" translate="label comment" type="obscure" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="0">
                    <label>API Key</label>
                    <comment><![CDATA[<a href="https://support.freshdesk.com/en/support/solutions/articles/215517">How to find your API key</a>]]></comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
            </group>
        </section>
    </system>
</config>
